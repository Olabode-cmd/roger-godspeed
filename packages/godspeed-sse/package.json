{
  "name": "@thraggs/godspeed-sse",
  "type": "module",
  "version": "1.0.2",
  "description": "Server-Sent Events (SSE) middleware for Godspeed HTTP client",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "bench": "bun tests/sse.bench.ts"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "@thraggs/godspeed": "^1.0.0"
  },
  "devDependencies": {
    "@thraggs/godspeed": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "godspeed",
    "sse",
    "server-sent-events",
    "eventsource",
    "plugin",
    "middleware"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thraggs/godspeed.git",
    "directory": "packages/godspeed-sse"
  },
  "bugs": {
    "url": "https://github.com/thraggs/godspeed/issues"
  },
  "author": "Thraggs",
  "license": "MIT"
}
